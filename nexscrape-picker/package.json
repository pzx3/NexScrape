    "lint": "eslint src/",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "css-what": "^6.1.0",
    "js-arabic-reshaper": "^1.0.0",
