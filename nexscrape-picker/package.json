{
  "name": "@nexscrape/picker",
  "version": "0.1.0",
  "private": true,
  "description": "NexPicker — Interactive element picker for NexScrape. Click once, scrape forever.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nex-pick": "dist/cli.js"
  },
  "scripts": {
